# AIO Framework Environment Configuration
# Copy to .env and fill in real values. Never commit secrets.

# LLM Provider
OPENAI_API_KEY=sk-your-openai-key-here

# LangSmith Observability (optional)
LANGCHAIN_API_KEY=ls-your-langsmith-key-here
LANGCHAIN_PROJECT=aio-priority-1
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=aio-framework

# Prometheus / Grafana
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=change-me

# Docker Sandbox
DOCKER_SOCKET_PATH=unix:///var/run/docker.sock
DOCKER_REGISTRY=

# Memory Bridge
MEMBRIDGE_CONNECTION_STRING=memory://localhost

# Runtime
AIO_LOG_LEVEL=INFO
SAFETY_MODE=strict
MAX_RETRIES=3
