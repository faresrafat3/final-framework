# AIO Framework Environment Configuration
# Copy to .env and fill in real values. Never commit secrets.

# LLM Provider
OPENAI_API_KEY=sk-your-openai-key-here

# LangSmith Observability (optional)
LANGCHAIN_API_KEY=ls-your-langsmith-key-here
LANGCHAIN_PROJECT=aio-priority-3
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=aio-framework

# Prometheus / Grafana
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=change-me

# Docker Sandbox
DOCKER_SOCKET_PATH=unix:///var/run/docker.sock
DOCKER_REGISTRY=

# Memory Bridge
MEMBRIDGE_CONNECTION_STRING=memory://localhost
ENABLE_REAL_EMBEDDINGS=false
MEMORY_BACKEND_TYPE=memory
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://localhost/aio

# Runtime
AIO_LOG_LEVEL=INFO
SAFETY_MODE=strict
MAX_RETRIES=3

# LLM-Based Planning
ENABLE_LLM_PLANNING=false
LLM_PLANNER_PROVIDER=openai
LLM_PLANNER_MODEL=gpt-4o
LLM_PLANNER_TEMPERATURE=0.2
LLM_PLANNER_MAX_TOKENS=1024
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Priority 3 Feature Flags (Layers 9–12)
ENABLE_PRIORITY_3=true
SELF_EVOLUTION_ENABLE=true
MULTI_AGENT_ENABLE=true
SAFETY_GOVERNANCE_ENABLE=true
COGNITIVE_IMMUNE_ENABLE=true
